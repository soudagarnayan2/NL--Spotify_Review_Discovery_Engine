# ============================================================
# Environment Variables for Railway (Backend) Deployment
# Copy this file to .env for local development.
# Set these as Railway service variables in the Railway dashboard.
# ============================================================

# ── LLM / Inference API Keys ─────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Spotify Developer API Credentials ─────────────────────────
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Set this to your Railway public URL + callback path, e.g.:
# https://your-app.up.railway.app/api/v1/spotify/callback
# Also register this exact URI in your Spotify App's Redirect URIs.
SPOTIFY_REDIRECT_URI=https://your-app.up.railway.app/api/v1/spotify/callback

# ── Reddit API (optional — for review scraping) ────────────────
# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=SpotifyDiscoveryAgent/1.0

# ── Mode Control ───────────────────────────────────────────────
# Set to 'offline' to skip live scraping (recommended for production)
WORKSPACE_MODE=offline
